# Environment Configuration
APP_ENV=production
APP_NAME="Amnezia VPN Panel"
SESSION_NAME=amnezia_panel_session

# Default locale
DEFAULT_LOCALE=en

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_DATABASE=amnezia_panel
DB_USERNAME=amnezia
DB_PASSWORD=CHANGE_ME_strong_db_password_here
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password_here

# Admin Account (auto-created on first run)
ADMIN_EMAIL=admin@amnez.ia
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# API Configuration
JWT_SECRET=CHANGE_ME_random_string_at_least_32_chars
API_RATE_LIMIT=100

# HTTP Basic Auth (protects the entire panel)
HTTP_AUTH_USER=admin
HTTP_AUTH_PASS=CHANGE_ME_strong_http_password

# VPN Defaults
DEFAULT_VPN_PORT_MIN=30000
DEFAULT_VPN_PORT_MAX=65000
DEFAULT_VPN_SUBNET=10.8.1.0/24
DEFAULT_DNS=1.1.1.1,1.0.0.1
